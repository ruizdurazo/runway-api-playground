# -----------------------------------------------------------------------------
# Next.js app (copy to .env.local)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# MCP server — packages/runway-mcp
# Load these in the shell when running `npm run mcp:dev` / `mcp-use start`,
# or copy this file to packages/runway-mcp/.env and use a tool that loads it.
# -----------------------------------------------------------------------------

# Required for the generate_media tool
RUNWAY_API_KEY=

# Public base URL the *browser* uses to load widget assets (`/mcp-use/widgets/...`).
# Must match the HTTP origin where this process is reachable. After `listen()`, mcp-use
# defaults to http://localhost:${PORT} (PORT defaults to 3000 if unset).
# If you terminate TLS or proxy on another port (e.g. 3001), set MCP_URL to that origin
# only if this server (or your reverse proxy) also serves `/mcp-use/**` on that host.
# Wrong MCP_URL → inspector console: ERR_CONNECTION_REFUSED for widget scripts.
MCP_URL=
