{
  "name": "runway-api-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --filter @runway-playground/shared run build && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "mcp:install": "npm install --prefix packages/runway-mcp",
    "mcp:dev": "npm run dev --prefix packages/runway-mcp",
    "mcp:build": "npm run build --prefix packages/runway-mcp",
    "build:mcp": "pnpm --filter @runway-playground/shared run build && pnpm --filter @runway-playground/mcp run build",
    "start:mcp": "pnpm --filter @runway-playground/mcp run start"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@runway-playground/shared": "file:packages/runway-shared",
    "@runwayml/sdk": "^2.8.2",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.1.2",
    "sass": "^1.91.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2"
  }
}
