{
  "name": "@runway-playground/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Runway media generation (MCP Apps)",
  "main": "dist/index.js",
  "scripts": {
    "build:shared": "tsc -p ../runway-shared/tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run build:shared && npm run typecheck && mcp-use build --no-typecheck",
    "dev": "mcp-use dev",
    "start": "npm run build && NODE_ENV=production mcp-use start"
  },
  "dependencies": {
    "@runway-playground/shared": "file:../runway-shared",
    "@runwayml/sdk": "^2.8.2",
    "mcp-use": "1.24.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.13.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.8"
  }
}
